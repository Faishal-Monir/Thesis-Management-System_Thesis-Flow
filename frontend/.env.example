# Frontend environment variables (example)
# Copy to `frontend/.env` and fill in your own values.

REACT_APP_API_BASE_URL=http://localhost:5005
REACT_APP_BACKEND_BASE_URL=http://localhost:5005
REACT_APP_FRONTEND_BASE_URL=http://localhost:3000

# Google OAuth button / flow
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
REACT_APP_GOOGLE_OAUTH_START=http://localhost:5005/auth/google/start
